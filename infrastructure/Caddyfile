# SOSO Server - Simplified Reverse Proxy Configuration

soso.dreampaste.com {
    # Global compression
    encode gzip

    # Basic security headers
    header {
        -Server
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
    }

    # Jenkins CI/CD Admin Panel
    redir /jenkins /jenkins/ permanent
    reverse_proxy /jenkins/* jenkins:8080 {
        header_up X-Forwarded-Proto {scheme}
    }

    # SOSO API Endpoints
    reverse_proxy /api/* api:8080 {
        header_up X-Forwarded-Proto {scheme}
        health_uri /api/actuator/health
        health_interval 30s
        health_timeout 10s
    }

    # API Documentation (Swagger UI)
    redir /swagger /swagger-ui/index.html permanent
    redir /swagger/ /swagger-ui/index.html permanent
    reverse_proxy /swagger-ui/* api:8080
    reverse_proxy /v3/api-docs* api:8080

    # Health & Documentation endpoints
    reverse_proxy /actuator/* api:8080
    reverse_proxy /docs/* api:8080

    # Static file caching
    @static {
        path *.css *.js *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot
    }
    header @static {
        Cache-Control "public, max-age=86400"
    }

    # Default route - redirect to Swagger when API is ready, Jenkins for now
    redir / /jenkins/ temporary

    # Simple error handling
    handle_errors {
        respond "Service temporarily unavailable" {http.error.status_code}
    }
}

# HTTP to HTTPS redirect
http://soso.dreampaste.com {
    redir https://soso.dreampaste.com{uri} permanent
}
